#
# Regression test for Array.prototype.shift Truffle performance warnings.
#
>[0r] js --experimental-options --engine.WarnInterpreterOnly=false --engine.CompilationFailureAction=ExitVM --engine.TraceCompilation=true --engine.CompileImmediately=true --engine.BackgroundCompilation=false --compiler.TracePerformanceWarnings=all ${TEST_DIR}/perf_warn_array_shift.js
(?s)^(?!.*perf warn).*$
opt done
